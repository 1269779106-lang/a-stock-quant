# A股量化交易系统配置文件
# 复制此文件为 .env 并填入实际配置

# 应用配置
APP_NAME=A股量化交易系统
APP_VERSION=0.1.0
DEBUG=true

# 数据库配置 (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_NAME=astock_quant

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Tushare配置 (可选，用于获取更多数据)
TUSHARE_TOKEN=your_tushare_token_here

# 数据存储路径
DATA_DIR=D:/a-stock-quant/data
